{
  "layer": "top",
  "position": "top",
  "spacing": 4,
  "margin-top": 5,
  "margin-bottom": 0,
  "margin-left": 5,
  "margin-right": 5,

  "modules-left": [
    "custom/icon",
    "hyprland/workspaces",
    "hyprland/window",
    "custom/spotify",
  ],

  "modules-center": [
    "clock"
  ],

  "modules-right": [
    "backlight",
    "pulseaudio",
    "network",
    "battery",
    "tray",
    "idle_inhibitor",
    "custom/updates",
    "custom/notification",
    "custom/power",
  ],
  
  "custom/icon": {
    "format": "≤░μΘ",
    "on-click": "kitty",
    "tooltip": false 
  },

  "cpu": {
    "interval": 10,
    "format": "ΎΤ╝ {usage}%",
    "max-length": 10,
    "tooltip": false
  },
  
  "clock": {
		"format": "<b>≤░ξΦ  {:%H:%M   ≤░Δφ  %d/%m}</b> ",
		//"format": "{:%a}",
		"tooltip-format": "<tt>{calendar}</tt>",
        "calendar": {
                    "mode"          : "month",
                    "format": {
                              "months":     "<span color='#cdd6f4'><b>{}</b></span>",
                              "days":       "<span color='#cdd6f4'><b>{}</b></span>",
                              "weeks":      "<span color='#cdd6f4'><b>W{}</b></span>",
                              "weekdays":   "<span color='#cdd6f4'><b>{}</b></span>",
                              "today":      "<span color='#f38ba8'><b>{}</b></span>"
                              }
                    },
    },

  "memory": {
    "interval": 30,
    "format": "ΎΕ╡ {used}GiB",
    "format-alt": "ΎΣ▓ {used:0.1f}G",
    "max-length": 10
  },

  "temperature": {
    "format": "ΎΜΚ {temperatureF}┬░F"
  },

  "hyprland/window": {
    "format": "ΎΓσ  {}",
    "rewrite": {
      "(.*) - NVIM": "ΎΞψ  NeoVim",
      "(.*) έΑΦ Mozilla Firefox": "≤░Ι╣  Firefox",
      "ΎΓσ  ": "≤░ΘΕ  Desktop",
      "(.*) Spotify Free": "≤░ΥΘ  Spotify",
      "(.*) Spotify": "≤░ΥΘ  Spotify",
      "ΎΓσ  ~": "ΎΓσ  daksh@arch",
    }
  },

    "hyprland/workspaces" : {
        "on-click": "activate",
        "active-only": false,
        "all-outputs": true,
        "format": "{icon}",
        "format-icons": {
			"urgent": "ΎΒς",
			"active": "ΎΗΤ",
			"default": "ΎΕΝ"
        },
        "persistent-workspaces": {
            "*": 6
        }       
    },
  
  "backlight": {
    "format": "{icon} <b>{percent}%</b>",
    "format-icons": ["≤░Δη", "≤░Δθ", "≤░Δι"],
    "tooltip": false,
   },

  "pulseaudio": {
    "format": "{icon} <b>{volume}%</b>",
    "format-bluetooth": "{icon} ΎΛΦ <b>{volume}%</b>",
    "format-bluetooth-muted": "≤░ζθ ΎΛΦ",
    "format-muted": " ≤░ζθ ",
    "format-icons": {
      "headset": "ΎΑξ",
      "default": ["≤░Χ┐", "≤░ΨΑ", "≤░Χ╛"],
    },
    "tooltip": false,
    "on-click": "pavucontrol",
  },

  "network": {
    "interval": 30,
    "format-wifi": "≤░νρ {essid}",
    "format-ethernet": "≤░ΙΑ Wired",
    "fomat-disconnected": "≤▒γ╡ Disconnected",
    "tooltip-format-wifi": "{essid} ({signalStrength}%)",
    "tooltip-format-ethernet": "{ifname} ΎΔΒ",
    "tooltip-format-disconnected": "Disconnected",
    "on-click": "nmtui",
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-icons": ["≤░ΓΟ", "≤░Β╗", "≤░Β╜", "≤░Β┐", "≤░ΓΒ", "≤░Β╣"],
    "max-length": 25,
    "tooltip": false,
  },


  "tray": {
    "icon-size": 18,
    "spacing": 10,
  },

   "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
        "activated": "≤░ΙΙέΑψ",
        "deactivated": "≤░ΙΚέΑψ"
    },
  },

  "custom/separator-space": {
    "format": " ",
    "tooltip": false,
  },

  "custom/separator-gap": {
    "format": "  ",
    "tooltip": false,
  },

  "custom/separator-arrow": {
    "format": " Όφ░ ",
    "tooltip": false,
  },

  "custom/spotify": {
        "format": "{} ΎΗ╝",
        "max-length": 60,
        "interval": "once",
        "return-type": "json",
        "exec": "~/.local/bin/spotifyctl",
        "on-click": "playerctl --player=spotify play-pause && pkill -RTMIN+30 waybar",
        "on-click-right": "playerctl --player=spotify loop track",
        "on-scroll-down": "playerctl --player=spotify previous && pkill -RTMIN+30 waybar",
        "on-scroll-up": "playerctl --player=spotify next && pkill -RTMIN+30 waybar",
        "on-click-middle": "pkill --signal TERM spotify",
        "signal": 30,
        "smooth-scrolling-threshold": 1.0,
  },

  "custom/power": {
    "format": "≤░Ρξ",
    "on-click": "wlogout",
    "tooltip": false,
  },
  "custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "≤▒ΖτέΑΚ",
      "none": "≤░ΓγέΑΚ",
      "dnd-notification": "≤░╡βέΑΚ",
      "dnd-none": "≤░ΓδέΑΚ",
      "inhibited-notification": "≤▒ΖτέΑΚ",
      "inhibited-none": "≤░ΓγέΑΚ",
      "dnd-inhibited-notification": "≤░╡βέΑΚ",
      "dnd-inhibited-none": "≤░ΓδέΑΜέΑΚ"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },

    "custom/updates": {
        "format": "ΎΓτ  {}",
        "tooltip-format": "{}",
        "escape": true,
        "return-type": "json",
        "exec": "~/.config/waybar/custom-scripts/updates",
        "restart-interval": 60,
        "on-click": "kitty -e ~/.config/waybar/custom-scripts/update",
        "tooltip": false
    },

}
